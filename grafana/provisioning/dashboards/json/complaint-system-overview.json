{
  "id": null,
  "uid": "complaint-overview",
  "title": "Complaint System Overview",
  "tags": ["complaints", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "JVM Memory Used",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes)",
          "legendFormat": "bytes",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Average API Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum[1m])) / sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "seconds",
          "refId": "A"
        }
      ]
    }
  ]
}
